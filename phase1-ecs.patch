+factory.clearAll();
+assert(world.entityCount === 0, `clearAll made entityCount 0, got ${world.entityCount}`);
+
+console.log(`\n${pass} passed, ${fail} failed`);
+if (fail === 0) {
+  console.log('PASS');
+  process.exit(0);
+} else {
+  console.log('FAIL');
+  process.exit(1);
+}
